{
  "name": "solemate",
  "version": "1.0.0",
  "description": "SoleMate ecommerce backend API",
  "main": "backend/index.js",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node backend/index.js",
    "dev": "nodemon backend/index.js",
    "test": "jest --config backend/jest.config.js --runInBand --detectOpenHandles",
    "test:coverage": "jest --config backend/jest.config.js --runInBand --coverage",
    "lint": "eslint backend",
    "lint:fix": "eslint backend --fix",
    "format": "prettier --write \"backend/**/*.js\"",
    "db:migrate": "node backend/DB/migrate.js",
    "db:seed": "node backend/DB/seed.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@stripe/react-stripe-js": "^3.6.0",
    "@stripe/stripe-js": "^7.1.0",
    "@supabase/supabase-js": "^2.49.4",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.15.6",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "stripe": "^18.0.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@babel/plugin-transform-runtime": "^7.26.10",
    "@babel/preset-env": "^7.26.9",
    "@eslint/js": "^9.11.1",
    "@jest/globals": "^29.7.0",
    "eslint": "^9.11.1",
    "globals": "^15.9.0",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "nodemon": "^3.1.7",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.3.3",
    "supertest": "^7.1.0"
  }
