# ============================================================================
# SoleMate backend — environment template
# Copy to .env and fill in. NEVER commit the real .env.
# ============================================================================

# Runtime
NODE_ENV=development
PORT=5000
LOG_LEVEL=debug

# Comma-separated list of allowed frontend origins (CORS)
CLIENT_URL=http://localhost:5173

# --- Database --------------------------------------------------------------
# Either provide a single DATABASE_URL (recommended for RDS / hosted DBs)...
# DATABASE_URL=postgres://user:pass@host:5432/solemate
# ...or the discrete fields below (used by docker-compose for local dev):
DB_USER=solemate
DB_PASSWORD=solemate
DB_HOST=localhost
DB_PORT=5432
DB_NAME=solemate
DB_SSL=false

# --- Auth ------------------------------------------------------------------
# Generate a strong value, e.g. `openssl rand -hex 32`
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=2h

# --- Stripe ----------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Object storage (product images) ---------------------------------------
SUPABASE_URL=https://your-project.supabase.co
API_KEY=your-supabase-service-key
STORAGE_BUCKET=solemate
